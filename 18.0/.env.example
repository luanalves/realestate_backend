# =============================================================================
# ENVIRONMENT VARIABLES - Odoo Production Stack
# =============================================================================
# Este arquivo documenta todas as variáveis de ambiente necessárias.
# 
# INSTRUÇÕES:
#   1. Copie este arquivo para .env (no mesmo diretório)
#   2. Substitua TODOS os valores TROCAR_* por valores reais
#   3. Gere senhas fortes usando: openssl rand -base64 32
#   4. NUNCA commite o arquivo .env no Git
#
# AMBIENTES:
#   - development: .env.local  (localhost)
#   - staging:     .env.staging (Dokploy staging)
#   - production:  .env.production (Dokploy production - configure via UI)
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=production
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# POSTGRESQL - Database
# -----------------------------------------------------------------------------
POSTGRES_DB=odoo_production
POSTGRES_USER=odoo_prod_user
POSTGRES_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# Database connection (use pelos outros serviços)
DB_HOST=db
DB_PORT=5432
DB_NAME=odoo_production
DB_USER=odoo_prod_user
DB_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# -----------------------------------------------------------------------------
# REDIS - Cache & Sessions
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS
REDIS_DBINDEX=1

# -----------------------------------------------------------------------------
# RABBITMQ - Message Queue
# -----------------------------------------------------------------------------
RABBITMQ_USER=odoo_mq_user
RABBITMQ_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS
RABBITMQ_DEFAULT_VHOST=/odoo_production

# -----------------------------------------------------------------------------
# CELERY - Async Tasks
# -----------------------------------------------------------------------------
# ATENÇÃO: As senhas devem ser as mesmas de RABBITMQ_PASSWORD e REDIS_PASSWORD
CELERY_BROKER_URL=amqp://odoo_mq_user:TROCAR_POR_SENHA_FORTE_32_CHARS@rabbitmq:5672//odoo_production
CELERY_RESULT_BACKEND=redis://:TROCAR_POR_SENHA_FORTE_32_CHARS@redis:6379/2
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# -----------------------------------------------------------------------------
# ODOO - Application
# -----------------------------------------------------------------------------
# Master Password (CRÍTICO - protege database manager)
ODOO_ADMIN_PASSWD=TROCAR_POR_SENHA_FORTE_64_CHARS

# Admin User Password (senha do usuário admin no primeiro login)
ODOO_NEW_ADMIN_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# Database Management
ODOO_LIST_DB=False
ODOO_DB_FILTER=^odoo_production$

# Server Configuration
ODOO_WORKERS=4
ODOO_MAX_CRON_THREADS=2
ODOO_PROXY_MODE=True
ODOO_LOG_LEVEL=info

# Limits
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1200
ODOO_LIMIT_REQUEST=8192
ODOO_LIMIT_MEMORY_HARD=2684354560
ODOO_LIMIT_MEMORY_SOFT=2147483648

# Data Directory
ODOO_DATA_DIR=/var/lib/odoo

# -----------------------------------------------------------------------------
# JWT - Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=TROCAR_POR_SECRET_FORTE_64_CHARS
JWT_ISSUER=https://seudominio.com
JWT_EXPIRATION=3600

# -----------------------------------------------------------------------------
# OAUTH2 - API Client Credentials
# -----------------------------------------------------------------------------
OAUTH_CLIENT_ID=TROCAR_POR_CLIENT_ID
OAUTH_CLIENT_SECRET=TROCAR_POR_CLIENT_SECRET

# -----------------------------------------------------------------------------
# TEST CREDENTIALS - Integration & E2E Tests
# -----------------------------------------------------------------------------
# These credentials are used by integration_tests/ and cypress/e2e/ tests.
# Never commit real values — always use test-specific seed accounts.
BASE_URL=http://localhost:8069

# Seed user credentials per RBAC profile (used in integration_tests/test_us15_*)
OWNER_EMAIL=TROCAR_POR_EMAIL_OWNER_TESTE
OWNER_PASS=TROCAR_POR_SENHA_OWNER_TESTE
MANAGER_EMAIL=TROCAR_POR_EMAIL_MANAGER_TESTE
MANAGER_PASS=TROCAR_POR_SENHA_MANAGER_TESTE
AGENT_EMAIL=TROCAR_POR_EMAIL_AGENT_TESTE
AGENT_PASS=TROCAR_POR_SENHA_AGENT_TESTE

# Multi-tenancy tests: Company A seed user
COMPANY_A_EMAIL=TROCAR_POR_EMAIL_COMPANY_A_TESTE
COMPANY_A_PASS=TROCAR_POR_SENHA_COMPANY_A_TESTE

# Cypress admin credentials (used in cypress/e2e/015_services_admin.cy.js via cypress.env.json)
ADMIN_EMAIL=TROCAR_POR_EMAIL_ADMIN_TESTE
ADMIN_PASSWORD=TROCAR_POR_SENHA_ADMIN_TESTE

# -----------------------------------------------------------------------------
# ODOO API - Celery Worker Access
# -----------------------------------------------------------------------------
# Credenciais para Celery workers acessarem Odoo via XML-RPC
ODOO_USER=admin
ODOO_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# -----------------------------------------------------------------------------
# FLOWER - Celery Monitoring
# -----------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS

# -----------------------------------------------------------------------------
# OPENTELEMETRY - Distributed Tracing (APM)
# -----------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=odoo-production
OTEL_SERVICE_VERSION=18.0
OTEL_DEPLOYMENT_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=tempo:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER=always_on
OTEL_LOG_LEVEL=info

# Sampling strategies:
#   - always_on: 100% (recomendado staging/dev)
#   - always_off: 0% (desabilita tracing)
#   - traceidratio:0.1: 10% (recomendado produção)
#   - traceidratio:0.01: 1% (alta carga)

# -----------------------------------------------------------------------------
# GRAFANA - Observability Dashboard
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TROCAR_POR_SENHA_FORTE_32_CHARS
GRAFANA_ROOT_URL=https://grafana.seudominio.com
GRAFANA_DOMAIN=grafana.seudominio.com

# -----------------------------------------------------------------------------
# TRAEFIK - Subdomains (non-local environments: production, staging, dev)
# -----------------------------------------------------------------------------
# Used by docker-compose.traefik.yml overlay.
# For local development these variables are not needed (ports are used instead).
# Each value is a full hostname (no https:// prefix).
ODOO_DOMAIN=seudominio.com
FLOWER_DOMAIN=flower.seudominio.com
MAILHOG_DOMAIN=mail.seudominio.com
RABBITMQ_DOMAIN=rabbitmq.seudominio.com

# -----------------------------------------------------------------------------
# EMAIL - SMTP Configuration (opcional)
# -----------------------------------------------------------------------------
# EMAIL_FROM=noreply@seudominio.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SSL=False
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=TROCAR_POR_APP_PASSWORD

# -----------------------------------------------------------------------------
# BACKUP - S3 Configuration (opcional)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=TROCAR_POR_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=TROCAR_POR_SECRET_KEY
# AWS_S3_BUCKET=seu-bucket-backup
# AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# SENTRY - Error Tracking (opcional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# INTEGRATION TESTS - Credenciais para scripts em integration_tests/
# -----------------------------------------------------------------------------
# Todos os scripts test_us15_s*.sh e similares leem estas variáveis.
# NUNCA use valores padrão nos scripts — defina aqui ou exporte antes de rodar.
#
# OAuth Client (deve corresponder ao registro em thedevkitchen_apigateway)
OAUTH_CLIENT_ID=TROCAR_POR_CLIENT_ID
OAUTH_CLIENT_SECRET=TROCAR_POR_CLIENT_SECRET

# Usuários de teste (per-profile)
OWNER_EMAIL=owner@suaimobiliaria.com.br
OWNER_PASS=TROCAR_POR_SENHA_OWNER
MANAGER_EMAIL=manager@suaimobiliaria.com.br
MANAGER_PASS=TROCAR_POR_SENHA_MANAGER
AGENT_EMAIL=agent@suaimobiliaria.com.br
AGENT_PASS=TROCAR_POR_SENHA_AGENT

# Multi-tenancy isolation test (S5)
COMPANY_A_EMAIL=owner@empresa-a.com.br
COMPANY_A_PASS=TROCAR_POR_SENHA_COMPANY_A

# Cypress E2E
ADMIN_EMAIL=admin@suaimobiliaria.com.br
ADMIN_PASSWORD=TROCAR_POR_SENHA_ADMIN

# =============================================================================
# NOTAS DE SEGURANÇA
# =============================================================================
# 
# 1. GERAR SENHAS FORTES:
#    openssl rand -base64 32  (para senhas de 32 chars)
#    openssl rand -base64 48  (para senhas de 64 chars)
#
# 2. VERIFICAR ANTES DO DEPLOY:
#    - Todas as senhas foram alteradas?
#    - Nenhuma senha padrão (admin, password, 123456)?
#    - .env está no .gitignore?
#    - Arquivo .env tem permissões restritas (chmod 600)?
#
# 3. ROTAÇÃO DE SENHAS:
#    - Master password: anual
#    - Database password: semestral
#    - JWT secret: trimestral
#    - Admin password: mensal (ou via política corporativa)
#
# 4. DOKPLOY:
#    - Configure variáveis via UI (não commite .env)
#    - Habilite "Create Environment File" checkbox
#    - Use Build-time Secrets para senhas muito sensíveis
#
# =============================================================================
