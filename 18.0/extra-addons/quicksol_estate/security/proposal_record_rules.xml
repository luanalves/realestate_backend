<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- 1. Base company isolation (all users)                        -->
        <!-- ============================================================ -->
        <record id="rule_proposal_company_isolation" model="ir.rule">
            <field name="name">Proposal: company isolation</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(5, 0, 0)]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================ -->
        <!-- 2. Owner: all proposals in company                           -->
        <!-- ============================================================ -->
        <record id="rule_proposal_owner_all" model="ir.rule">
            <field name="name">Proposal: owner sees all in company</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_owner'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ============================================================ -->
        <!-- 3. Manager: all proposals in company                         -->
        <!-- ============================================================ -->
        <record id="rule_proposal_manager_all" model="ir.rule">
            <field name="name">Proposal: manager sees all in company</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ============================================================ -->
        <!-- 4. Agent: only own proposals                                  -->
        <!-- ============================================================ -->
        <record id="rule_proposal_agent_own" model="ir.rule">
            <field name="name">Proposal: agent sees own proposals only</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="domain_force">[
                ('agent_id.user_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_agent'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ============================================================ -->
        <!-- 5. Receptionist: read-only access to all company proposals   -->
        <!-- ============================================================ -->
        <record id="rule_proposal_receptionist_readonly" model="ir.rule">
            <field name="name">Proposal: receptionist read-only (FR-036)</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_receptionist'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Prospector: no record rule — access denied entirely via ir.model.access.csv -->

    </data>
</odoo>
