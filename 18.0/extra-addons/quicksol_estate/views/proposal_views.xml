<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <!-- ============================================================
             Action: Proposals (loaded by menus)
             ============================================================ -->
        <record id="action_real_estate_proposals" model="ir.actions.act_window">
            <field name="name">Proposals</field>
            <field name="res_model">real.estate.proposal</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="context">{'search_default_my_proposals': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first property proposal!
                </p>
                <p>
                    Manage sale and lease proposals, track negotiations,
                    and stay informed at every step of the deal.
                </p>
            </field>
        </record>

        <!-- ============================================================
             Search view
             ============================================================ -->
        <record id="view_real_estate_proposal_search" model="ir.ui.view">
            <field name="name">real.estate.proposal.search</field>
            <field name="model">real.estate.proposal</field>
            <field name="arch" type="xml">
                <search string="Proposals">
                    <field name="proposal_code" string="Proposal Code"/>
                    <field name="partner_id" string="Client"/>
                    <field name="property_id" string="Property"/>
                    <field name="agent_id" string="Agent"/>
                    <separator/>
                    <filter string="My Proposals" name="my_proposals"
                            domain="[('agent_id.user_id', '=', uid)]"/>
                    <filter string="Active" name="active"
                            domain="[('state', 'in', ('draft','sent','negotiation','queued'))]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Sent" name="sent" domain="[('state','=','sent')]"/>
                    <filter string="Queued" name="queued" domain="[('state','=','queued')]"/>
                    <filter string="Negotiation" name="negotiation" domain="[('state','=','negotiation')]"/>
                    <filter string="Accepted" name="accepted" domain="[('state','=','accepted')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                    <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('state','=','cancelled')]"/>
                    <separator/>
                    <filter string="Sale" name="type_sale" domain="[('proposal_type','=','sale')]"/>
                    <filter string="Lease" name="type_lease" domain="[('proposal_type','=','lease')]"/>
                    <group expand="0" string="Group By">
                        <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                        <filter string="Agent" name="group_agent" context="{'group_by':'agent_id'}"/>
                        <filter string="Property" name="group_property" context="{'group_by':'property_id'}"/>
                        <filter string="Type" name="group_type" context="{'group_by':'proposal_type'}"/>
                        <filter string="Month" name="group_month" context="{'group_by':'create_date:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================
             List view (minimal — full version in US1/T022)
             ============================================================ -->
        <record id="view_real_estate_proposal_list" model="ir.ui.view">
            <field name="name">real.estate.proposal.list</field>
            <field name="model">real.estate.proposal</field>
            <field name="arch" type="xml">
                <list string="Proposals" decoration-success="state == 'accepted'"
                      decoration-warning="state in ('sent','negotiation')"
                      decoration-muted="state in ('expired','cancelled','rejected')"
                      decoration-info="state in ('draft','queued')">
                    <field name="proposal_code" optional="show"/>
                    <field name="property_id"/>
                    <field name="partner_id" string="Client"/>
                    <field name="agent_id"/>
                    <field name="proposal_type"/>
                    <field name="proposal_value" widget="monetary"
                           options="{'currency_field': 'currency_id'}"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'accepted'"
                           decoration-warning="state in ('sent','negotiation')"
                           decoration-danger="state in ('rejected','expired')"
                           decoration-muted="state == 'cancelled'"
                           decoration-info="state in ('draft','queued')"/>
                    <field name="valid_until" optional="show"/>
                    <field name="queue_position" optional="hide"/>
                    <field name="create_date" string="Created" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Kanban view (minimal — full version in US1/T022)
             ============================================================ -->
        <record id="view_real_estate_proposal_kanban" model="ir.ui.view">
            <field name="name">real.estate.proposal.kanban</field>
            <field name="model">real.estate.proposal</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="proposal_code"/>
                    <field name="partner_id"/>
                    <field name="property_id"/>
                    <field name="proposal_value"/>
                    <field name="currency_id"/>
                    <field name="state"/>
                    <field name="agent_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="proposal_code"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="property_id"/>
                                    </div>
                                    <div>
                                        <field name="partner_id"/>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <field name="proposal_value" widget="monetary"
                                                   options="{'currency_field': 'currency_id'}"/>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="agent_id" widget="many2one_avatar_user"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ============================================================
             Form view (minimal — full version in US1/T022)
             ============================================================ -->
        <record id="view_real_estate_proposal_form" model="ir.ui.view">
            <field name="name">real.estate.proposal.form</field>
            <field name="model">real.estate.proposal</field>
            <field name="arch" type="xml">
                <form string="Proposal">
                    <header>
                        <button name="action_send" string="Send" type="object"
                                invisible="state != 'draft'"
                                class="btn-primary"/>
                        <button name="action_accept" string="Accept"
                                type="object"
                                invisible="state not in ('sent', 'negotiation')"
                                groups="quicksol_estate.group_real_estate_manager,quicksol_estate.group_real_estate_owner"
                                class="btn-success"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,sent,negotiation,accepted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="proposal_code" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Main Details">
                                <field name="property_id"
                                       readonly="state not in ('draft',)"/>
                                <field name="partner_id" string="Client"
                                       readonly="state not in ('draft',)"/>
                                <field name="agent_id"
                                       readonly="state not in ('draft',)"
                                       groups="quicksol_estate.group_real_estate_manager,quicksol_estate.group_real_estate_owner"/>
                                <field name="proposal_type"
                                       readonly="state not in ('draft',)"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group string="Financial">
                                <field name="proposal_value"
                                       readonly="state not in ('draft','sent','negotiation')"/>
                                <field name="currency_id"/>
                                <field name="valid_until"
                                       readonly="state not in ('draft','sent','negotiation')"/>
                                <field name="queue_position" readonly="1"
                                       invisible="state != 'queued'"/>
                            </group>
                        </group>
                        <group string="Dates">
                            <field name="sent_date" readonly="1"/>
                            <field name="accepted_date" readonly="1"
                                   invisible="state != 'accepted'"/>
                            <field name="rejected_date" readonly="1"
                                   invisible="state != 'rejected'"/>
                        </group>
                        <group string="Notes">
                            <field name="description" nolabel="1" widget="html"
                                   readonly="state in ('accepted','rejected','expired','cancelled')"/>
                        </group>
                        <group invisible="not rejection_reason">
                            <field name="rejection_reason" readonly="1"/>
                        </group>
                        <group invisible="not cancellation_reason">
                            <field name="cancellation_reason" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Lead" name="lead">
                                <field name="lead_id" readonly="1"/>
                            </page>
                            <page string="Chain" name="chain"
                                  invisible="not parent_proposal_id and not child_proposal_ids">
                                <field name="parent_proposal_id" readonly="1"/>
                                <field name="child_proposal_ids" readonly="1">
                                    <list>
                                        <field name="proposal_code"/>
                                        <field name="proposal_value" widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="state"/>
                                        <field name="create_date"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================================
             Menu entry (under Real Estate main menu)
             ============================================================ -->
        <menuitem id="menu_real_estate_proposals"
                  name="Proposals"
                  parent="quicksol_estate.menu_real_estate_root"
                  action="action_real_estate_proposals"
                  sequence="25"
                  groups="quicksol_estate.group_real_estate_owner,quicksol_estate.group_real_estate_manager,quicksol_estate.group_real_estate_agent,quicksol_estate.group_real_estate_receptionist"/>
    </data>
</odoo>
