<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             Action: Service Sources
             ============================================================ -->
        <record id="action_real_estate_service_sources" model="ir.actions.act_window">
            <field name="name">Origens de Atendimento</field>
            <field name="res_model">real.estate.service.source</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Nenhuma origem encontrada.
                </p>
                <p>
                    Cadastre origens para identificar como o cliente chegou até você.
                </p>
            </field>
        </record>

        <!-- ============================================================
             List View
             ============================================================ -->
        <record id="view_real_estate_service_source_list" model="ir.ui.view">
            <field name="name">real.estate.service.source.list</field>
            <field name="model">real.estate.service.source</field>
            <field name="arch" type="xml">
                <list string="Origens de Atendimento">
                    <field name="name" string="Nome"/>
                    <field name="code" string="Código"/>
                    <field name="active" string="Ativo" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ============================================================
             Form View
             ============================================================ -->
        <record id="view_real_estate_service_source_form" model="ir.ui.view">
            <field name="name">real.estate.service.source.form</field>
            <field name="model">real.estate.service.source</field>
            <field name="arch" type="xml">
                <form string="Origem de Atendimento">
                    <sheet>
                        <group>
                            <field name="name" string="Nome"/>
                            <field name="code" string="Código"
                                   placeholder="ex: whatsapp, portal, indicacao"/>
                            <field name="active" string="Ativo"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
