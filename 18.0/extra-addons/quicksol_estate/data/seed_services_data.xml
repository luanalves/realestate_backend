<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!--
            Feature 015: Seed Services — covers all 7 stages for dev/test.
            Uses seed_ prefix xml_ids so they can be re-created safely.
            T072 — idempotent (noupdate="0").
        -->

        <!-- Stage: no_service -->
        <record id="seed_service_001" model="real.estate.service">
            <field name="client_name">Cliente Seed 001 (no_service)</field>
            <field name="operation_type">rental</field>
            <field name="stage">no_service</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: prospecting -->
        <record id="seed_service_002" model="real.estate.service">
            <field name="client_name">Cliente Seed 002 (prospecting)</field>
            <field name="operation_type">sale</field>
            <field name="stage">prospecting</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: visit -->
        <record id="seed_service_003" model="real.estate.service">
            <field name="client_name">Cliente Seed 003 (visit)</field>
            <field name="operation_type">rental</field>
            <field name="stage">visit</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: proposal -->
        <record id="seed_service_004" model="real.estate.service">
            <field name="client_name">Cliente Seed 004 (proposal)</field>
            <field name="operation_type">sale</field>
            <field name="stage">proposal</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: negotiation -->
        <record id="seed_service_005" model="real.estate.service">
            <field name="client_name">Cliente Seed 005 (negotiation)</field>
            <field name="operation_type">purchase</field>
            <field name="stage">negotiation</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: won -->
        <record id="seed_service_006" model="real.estate.service">
            <field name="client_name">Cliente Seed 006 (won)</field>
            <field name="operation_type">rental</field>
            <field name="stage">won</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Stage: lost -->
        <record id="seed_service_007" model="real.estate.service">
            <field name="client_name">Cliente Seed 007 (lost)</field>
            <field name="operation_type">sale</field>
            <field name="stage">lost</field>
            <field name="lost_reason">Desistência do cliente</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- With tags (tests many2many) -->
        <record id="seed_service_008" model="real.estate.service">
            <field name="client_name">Cliente Seed 008 (com tags)</field>
            <field name="operation_type">rental</field>
            <field name="stage">prospecting</field>
            <field name="tag_ids" eval="[(4, ref('quicksol_estate.service_tag_quente'))]"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Orphan (no agent) -->
        <record id="seed_service_009" model="real.estate.service">
            <field name="client_name">Cliente Seed 009 (orphan)</field>
            <field name="operation_type">sale</field>
            <field name="stage">no_service</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- With source -->
        <record id="seed_service_010" model="real.estate.service">
            <field name="client_name">Cliente Seed 010 (com origem)</field>
            <field name="operation_type">rental</field>
            <field name="stage">visit</field>
            <field name="company_id" ref="base.main_company"/>
        </record>

    </data>
</odoo>
