<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- tracking_disable impede o partner_autocomplete de disparar chamadas IAP ao criar empresas -->
    <data noupdate="0" context="{'tracking_disable': True, 'no_recompute': True}">
        <!--
            SEED: Imobiliária Seed — Ambiente de Testes
            ============================================================
            Cria uma imobiliária dedicada a testes com um usuário para
            cada perfil do RBAC (9 internos + 1 tenant portal + 1 portal
            proprietário). Não interfere no usuário admin do Odoo.

            Credenciais padrão: seed@<perfil>.com.br / seed123
            Empresa: Imobiliária Seed (CNPJ 55.444.333/0001-00)

            CPFs válidos gerados matematicamente (não use em produção).
            ============================================================
        -->

        <!-- ============================================================ -->
        <!-- 1. EMPRESA                                                    -->
        <!-- ============================================================ -->
        <record id="company_seed_imobiliaria" model="res.company">
            <field name="name">Imobiliária Seed</field>
            <field name="is_real_estate" eval="True"/>
            <field name="legal_name">Seed Imóveis LTDA</field>
            <field name="cnpj">55.444.333/0001-00</field>
            <field name="creci">CRECI/SP 99001</field>
            <field name="email">contato@imobiliaria-seed.com.br</field>
            <field name="phone">+55 (11) 99000-0001</field>
            <field name="street">Rua dos Testes, 1</field>
            <field name="city">São Paulo</field>
            <field name="zip">01310-100</field>
            <field name="active" eval="True"/>
        </record>

        <!-- ============================================================ -->
        <!-- 2. USUÁRIOS INTERNOS                                          -->
        <!-- ============================================================ -->

        <!-- Owner -->
        <record id="user_seed_owner" model="res.users">
            <field name="name">Seed Owner</field>
            <field name="login">owner@seed.com.br</field>
            <field name="password">seed123</field>
            <field name="email">owner@seed.com.br</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('base.group_user'),
                ref('quicksol_estate.group_real_estate_owner')
            ])]"/>
            <field name="company_ids" eval="[(6, 0, [
                ref('quicksol_estate.company_seed_imobiliaria')
            ])]"/>
            <field name="company_id" ref="quicksol_estate.company_seed_imobiliaria"/>
        </record>

        <!-- Director -->
        <record id="user_seed_director" model="res.users">
            <field name="name">Seed Director</field>
            <field name="login">director@seed.com.br</field>
            <field name="password">seed123</field>
            <field name="email">director@seed.com.br</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('base.group_user'),
                ref('quicksol_estate.group_real_estate_director')
            ])]"/>
            <field name="company_ids" eval="[(6, 0, [
