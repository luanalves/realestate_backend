<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Daily cron to expire proposals past their valid_until date (FR-026, US8) -->
        <record id="cron_expire_proposals" model="ir.cron">
            <field name="name">Proposal: Auto-expire past valid_until</field>
            <field name="model_id" ref="model_real_estate_proposal"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_proposals()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
