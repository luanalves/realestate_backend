<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Daily cron: recompute is_pending for active services (FR-015).
             Runs at ~03:00 UTC (nextcall set to a past date so it fires ASAP on install,
             then repeats every 24h). -->
        <record id="cron_service_recompute_pendency" model="ir.cron">
            <field name="name">Service: Recompute pendency status (is_pending)</field>
            <field name="model_id" ref="model_real_estate_service"/>
            <field name="state">code</field>
            <field name="code">model._cron_recompute_pendency()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
