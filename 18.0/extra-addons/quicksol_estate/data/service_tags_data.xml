<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- System tag "Encerrado" (closed) — bootstrapped by post_init hook per company.
             This XML record is the global template; the hook creates per-company copies.
             is_system=True makes it immutable (FR-018) and locks pipeline (FR-007).
             noupdate="0" so upgrades reflect any name/color fix in XML. -->
        <record id="seed_service_tag_closed" model="real.estate.service.tag">
            <field name="name">Encerrado</field>
            <field name="color">#7f8c8d</field>
            <field name="is_system" eval="True"/>
            <!-- company_id left empty — the post_init hook creates per-company copies -->
        </record>
    </data>
</odoo>
