<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Service (Atendimento) sequence: ATD/YYYY/NNNNN
             company_id=False → Odoo creates a per-company copy automatically.
             noupdate="1" prevents resetting number_next on module upgrade. -->
        <record id="seq_real_estate_service" model="ir.sequence">
            <field name="name">Real Estate Service (Atendimento)</field>
            <field name="code">real.estate.service</field>
            <field name="prefix">ATD/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
