{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProposalCreate",
  "type": "object",
  "required": ["property_id", "client_name", "client_document", "agent_id", "proposal_type", "proposal_value"],
  "additionalProperties": false,
  "properties": {
    "property_id":      { "type": "integer", "minimum": 1 },
    "client_name":      { "type": "string", "minLength": 2, "maxLength": 200 },
    "client_document":  { "type": "string", "minLength": 11, "maxLength": 18 },
    "client_email":     { "type": ["string", "null"], "format": "email" },
    "client_phone":     { "type": ["string", "null"], "maxLength": 30 },
    "agent_id":         { "type": "integer", "minimum": 1 },
    "proposal_type":    { "type": "string", "enum": ["sale", "lease"] },
    "proposal_value":   { "type": "number", "exclusiveMinimum": 0 },
    "valid_until":      { "type": ["string", "null"], "format": "date" },
    "description":      { "type": ["string", "null"], "maxLength": 4000 },
    "lead_id":          { "type": ["integer", "null"], "minimum": 1 }
  }
}
