{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StageChangeInput",
  "description": "Request body for PATCH /api/v1/services/{id}/stage",
  "type": "object",
  "required": ["stage"],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["no_service", "in_service", "visit", "proposal", "formalization", "won", "lost"]
    },
    "lost_reason": {"type": "string", "minLength": 1, "maxLength": 500},
    "comment": {"type": "string", "maxLength": 1000}
  },
  "additionalProperties": false
}
