{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServiceUpdateInput",
  "description": "Request body for PUT /api/v1/services/{id}",
  "type": "object",
  "minProperties": 1,
  "properties": {
    "operation_type": {
      "type": "string",
      "enum": ["sale", "rent"]
    },
    "source_id": {"type": "integer", "minimum": 1},
    "tag_ids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "property_ids": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "notes": {"type": "string", "maxLength": 5000}
  },
  "additionalProperties": false
}
