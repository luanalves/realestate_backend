<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Password Token: Company Isolation -->
        <record id="rule_password_token_company" model="ir.rule">
            <field name="name">Password Token: Company Isolation</field>
            <field name="model_id" ref="model_thedevkitchen_password_token"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
    </data>

    <!-- Feature 022 / ADR-029: SaaS Admin cross-company override (applied on every upgrade) -->
    <data noupdate="0">

        <record id="rule_password_token_admin_all" model="ir.rule">
            <field name="name">System Admin: All Password Tokens (Cross-Company)</field>
            <field name="model_id" ref="model_thedevkitchen_password_token"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>
