<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Company isolation rule — applied to all CRUD on CreditCheck -->
        <record id="rule_credit_check_company" model="ir.rule">
            <field name="name">Credit Check: company isolation</field>
            <field name="model_id" ref="model_thedevkitchen_estate_credit_check"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('quicksol_estate.group_real_estate_owner')),
                                        (4, ref('quicksol_estate.group_real_estate_manager')),
                                        (4, ref('quicksol_estate.group_real_estate_agent')),
                                        (4, ref('quicksol_estate.group_real_estate_receptionist'))]"/>
        </record>

    </data>

    <!-- Feature 022 / ADR-029: SaaS Admin cross-company override (applied on every upgrade) -->
    <data noupdate="0">

        <record id="rule_credit_check_admin_all" model="ir.rule">
            <field name="name">System Admin: All Credit Checks (Cross-Company)</field>
            <field name="model_id" ref="model_thedevkitchen_estate_credit_check"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>
