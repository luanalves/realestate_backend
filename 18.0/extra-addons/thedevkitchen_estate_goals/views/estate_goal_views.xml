<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List view (Odoo 18 uses <list>) -->
        <record id="view_estate_goal_list" model="ir.ui.view">
            <field name="name">thedevkitchen.estate.goal.list</field>
            <field name="model">thedevkitchen.estate.goal</field>
            <field name="arch" type="xml">
                <list string="Goals">
                    <field name="user_id"/>
                    <field name="year"/>
                    <field name="month"/>
                    <field name="metric_type"/>
                    <field name="operation_type"/>
                    <field name="target_count"/>
                    <field name="target_vgv"
                           invisible="metric_type not in ('captacao', 'propostas', 'fechamento')"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_estate_goal_form" model="ir.ui.view">
            <field name="name">thedevkitchen.estate.goal.form</field>
            <field name="model">thedevkitchen.estate.goal</field>
            <field name="arch" type="xml">
                <form string="Goal">
                    <sheet>
                        <group>
                            <group>
                                <field name="user_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="year"/>
                                <field name="month"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group string="Metric">
                            <field name="metric_type"/>
                            <field name="operation_type"/>
                            <field name="target_count"/>
                            <field name="target_vgv"
                                   invisible="metric_type not in ('captacao', 'propostas', 'fechamento')"/>
                            <field name="currency_id"
                                   invisible="metric_type not in ('captacao', 'propostas', 'fechamento')"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_estate_goal_search" model="ir.ui.view">
            <field name="name">thedevkitchen.estate.goal.search</field>
            <field name="model">thedevkitchen.estate.goal</field>
            <field name="arch" type="xml">
                <search string="Search Goals">
                    <field name="user_id"/>
                    <field name="year"/>
                    <field name="month"/>
                    <field name="metric_type"/>
                    <field name="operation_type"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Agent" name="group_user" context="{'group_by': 'user_id'}"/>
                        <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                        <filter string="Month" name="group_month" context="{'group_by': 'month'}"/>
                        <filter string="Metric" name="group_metric" context="{'group_by': 'metric_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_estate_goal" model="ir.actions.act_window">
            <field name="name">Goals</field>
            <field name="res_model">thedevkitchen.estate.goal</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">No goals defined yet.</p>
                <p>Create goals per agent, metric, and period.</p>
            </field>
        </record>

        <!-- Menu items -->
        <menuitem
            id="menu_estate_goals_root"
            name="Goals"
            parent="quicksol_estate.menu_real_estate_main"
            sequence="50"/>

        <menuitem
            id="menu_estate_goals_list"
            name="Manage Goals"
            parent="menu_estate_goals_root"
            action="action_estate_goal"
            sequence="10"/>

    </data>
</odoo>
