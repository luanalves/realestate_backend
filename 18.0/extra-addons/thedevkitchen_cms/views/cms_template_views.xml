<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===================== CMS TEMPLATE: LIST VIEW ===================== -->
        <record id="view_cms_template_list" model="ir.ui.view">
            <field name="name">thedevkitchen.cms.template.list</field>
            <field name="model">thedevkitchen.cms.template</field>
            <field name="arch" type="xml">
                <list string="CMS Templates">
                    <field name="name"/>
                    <field name="category"/>
                    <field name="active"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="create_date" string="Created At" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ===================== CMS TEMPLATE: FORM VIEW ===================== -->
        <record id="view_cms_template_form" model="ir.ui.view">
            <field name="name">thedevkitchen.cms.template.form</field>
            <field name="model">thedevkitchen.cms.template</field>
            <field name="arch" type="xml">
                <form string="CMS Template">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Template Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="category"/>
                                <field name="active"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Content" name="content">
                                <!-- Odoo UI: rich HTML editor for admin editing -->
                                <field name="html_content" widget="html" nolabel="1"
                                       placeholder="Write template content here..."/>
                            </page>
                            <page string="Puck JSON (API)" name="puck_content">
                                <!-- API: raw Puck editor JSON payload -->
                                <field name="content_ids" nolabel="1">
                                    <list>
                                        <field name="content" widget="text"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===================== CMS TEMPLATE: ACTION ===================== -->
        <record id="action_cms_templates" model="ir.actions.act_window">
            <field name="name">CMS Templates</field>
            <field name="res_model">thedevkitchen.cms.template</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
