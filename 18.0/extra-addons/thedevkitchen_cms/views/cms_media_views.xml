<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===================== CMS MEDIA: LIST VIEW ===================== -->
        <record id="view_cms_media_list" model="ir.ui.view">
            <field name="name">thedevkitchen.cms.media.list</field>
            <field name="model">thedevkitchen.cms.media</field>
            <field name="arch" type="xml">
                <list string="CMS Media">
                    <field name="name"/>
                    <field name="media_type"/>
                    <field name="mime_type"/>
                    <field name="file_size" string="Size (bytes)"/>
                    <field name="url"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="create_date" string="Uploaded At" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ===================== CMS MEDIA: FORM VIEW ===================== -->
        <record id="view_cms_media_form" model="ir.ui.view">
            <field name="name">thedevkitchen.cms.media.form</field>
            <field name="model">thedevkitchen.cms.media</field>
            <field name="arch" type="xml">
                <form string="CMS Media">
                    <sheet>
                        <!-- Upload section (always visible, primary action) -->
                        <group string="Upload">
                            <field name="file_upload" widget="binary"
                                   filename="file_upload_filename"
                                   string="File"
                                   nolabel="0"/>
                            <field name="file_upload_filename" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>

                        <!-- Image preview (only for saved image records) -->
                        <field name="image_1920" widget="image" nolabel="1"
                               class="o_field_image"
                               invisible="media_type != 'image' or not attachment_id"/>

                        <!-- File metadata (auto-populated, readonly, shown after upload) -->
                        <group string="File Information" invisible="not attachment_id">
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="media_type" readonly="1"/>
                                <field name="mime_type" readonly="1"/>
                                <field name="file_size" string="Size (bytes)" readonly="1"/>
                            </group>
                            <group>
                                <field name="url" widget="url" string="File URL (API)" readonly="1"/>
                                <field name="attachment_id" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===================== CMS MEDIA: ACTION ===================== -->
        <record id="action_cms_media" model="ir.actions.act_window">
            <field name="name">CMS Media</field>
            <field name="res_model">thedevkitchen.cms.media</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
