{
  "title": "Kong API Gateway",
  "uid": "kong-apigateway",
  "tags": ["kong", "gateway", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kong_http_requests_total, service)",
        "label": "Service",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kong_http_requests_total{service=~\"$service\"}, route)",
        "label": "Route",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=~\"$service\", route=~\"$route\"}[1m])) by (service, route)",
          "legendFormat": "{{service}} / {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kong_http_requests_total{service=~\"$service\", code=~\"4..|5..\"}[1m])) by (service, code)",
          "legendFormat": "{{service}} HTTP {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latência p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kong_request_latency_ms_bucket{service=~\"$service\"}[1m])) by (le, service))",
          "legendFormat": "p50 {{service}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kong_request_latency_ms_bucket{service=~\"$service\"}[1m])) by (le, service))",
          "legendFormat": "p95 {{service}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kong_request_latency_ms_bucket{service=~\"$service\"}[1m])) by (le, service))",
          "legendFormat": "p99 {{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 4,
      "title": "Upstream Health",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(kong_upstream_target_health{state=\"healthy\"}) by (upstream)",
          "legendFormat": "{{upstream}} healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "Bandwidth (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kong_bandwidth_bytes_total{direction=\"ingress\", service=~\"$service\"}[1m])) by (service)",
          "legendFormat": "ingress {{service}}"
        },
        {
          "expr": "sum(rate(kong_bandwidth_bytes_total{direction=\"egress\", service=~\"$service\"}[1m])) by (service)",
          "legendFormat": "egress {{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "title": "Requests por HTTP Status Code",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(kong_http_requests_total{service=~\"$service\"}[1h])) by (code)",
          "legendFormat": "HTTP {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] }
    },
    {
      "id": 7,
      "title": "Logs do Kong",
      "type": "logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"kong-gateway|kong-token-refresher\"}",
          "legendFormat": ""
        }
      ],
      "options": { "showTime": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 8,
      "title": "Traces do Kong (últimas 1h)",
      "type": "traces",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "search",
          "serviceName": "kong-apigateway",
          "limit": 20
        }
      ]
    }
  ]
}
