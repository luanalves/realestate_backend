{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-branches.sh",
            "if": "Bash(git *)",
            "statusMessage": "Verificando branch protegida..."
          }
        ]
      }
    ]
  }
}
